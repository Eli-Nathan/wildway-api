{
  "kind": "collectionType",
  "collectionName": "guides",
  "info": {
    "singularName": "guide",
    "pluralName": "guides",
    "displayName": "Guides",
    "description": "Safety and informational guides linked to site types and facilities"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "link_message": {
      "type": "string",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "feature_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "site_types": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::site-type.site-type",
      "inversedBy": "guides"
    },
    "facilities": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::facility.facility",
      "inversedBy": "guides"
    },
    "SEO": {
      "displayName": "SEO block",
      "type": "component",
      "repeatable": false,
      "component": "seo.seo-block"
    }
  }
}
