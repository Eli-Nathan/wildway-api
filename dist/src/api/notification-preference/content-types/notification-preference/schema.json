        "email_route_favourites": {
            "type": "boolean",
            "default": true
        },
        "push_status_changes": {
            "type": "boolean",
            "default": true
        },
        "push_review_replies": {
            "type": "boolean",
            "default": true
        },
        "push_new_reviews": {
            "type": "boolean",
            "default": true
        },
        "push_likes": {
            "type": "boolean",
            "default": true
        },
        "push_route_favourites": {
            "type": "boolean",
            "default": true
        },
        "mute_all": {
            "type": "boolean",
