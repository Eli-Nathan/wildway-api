{
    "kind": "collectionType",
    "collectionName": "reviews",
    "info": {
        "singularName": "review",
        "pluralName": "reviews",
        "displayName": "Reviews",
        "description": "User reviews with ratings and images"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "review": {
            "type": "text",
            "required": false
        },
        "rating": {
            "type": "integer",
            "required": true,
            "min": 1,
            "max": 5
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"]
        },
        "owner": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::auth-user.auth-user",
            "inversedBy": "reviews"
        },
        "moderation_status": {
            "type": "enumeration",
            "enum": [
                "submitted",
                "pending",
                "moderating",
                "rejected",
                "complete"
            ],
            "default": "submitted"
        },
        "site": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::site.site",
            "inversedBy": "reviews"
        },
        "owner_reply": {
            "type": "text",
            "required": false
        },
        "owner_reply_at": {
            "type": "datetime",
            "required": false
        }
    }
}
