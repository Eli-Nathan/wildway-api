{
    "kind": "collectionType",
    "collectionName": "site_lists",
    "info": {
        "singularName": "site-list",
        "pluralName": "site-lists",
        "displayName": "Site Lists",
        "description": "Curated lists of sites (e.g., Munros, Wild Swimming Spots)"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "maxLength": 100
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "description": {
            "type": "text",
            "maxLength": 500
        },
        "icon": {
            "type": "string"
        },
        "iconify": {
            "type": "string"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"]
        },
        "difficulty": {
            "type": "enumeration",
            "enum": ["Easy", "Moderate", "Difficult", "Expert"]
        },
        "category": {
            "type": "enumeration",
            "enum": ["Walks"],
            "default": "Walks",
            "required": true
        },
        "owner_type": {
            "type": "enumeration",
            "enum": ["admin", "user"],
            "default": "admin",
            "required": true
        },
        "owner": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::auth-user.auth-user",
            "inversedBy": "site_lists"
        },
        "sites": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::site.site",
            "inversedBy": "site_lists"
        },
        "public": {
            "type": "boolean",
            "default": true
        },
        "saved_by": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::auth-user.auth-user",
            "inversedBy": "saved_site_lists"
        },
        "priority": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 10
        },
        "sortable_fields": {
            "type": "component",
            "repeatable": true,
            "component": "list.sortable-field"
        }
    }
}
